        "LTR / Vertical": "#6366F1"
      }
    },
    { "key": "originDate", "label": "Approximate Origin", "type": "text" },
    { "key": "sampleText", "label": "Sample Text", "type": "text" },
    { "key": "relatedScripts", "label": "Related Scripts", "type": "tags", "referenceItems": true },
    { "key": "description", "label": "Description", "type": "markdown" },
    { "key": "historicalNotes", "label": "Historical Notes", "type": "markdown" }
  ]
