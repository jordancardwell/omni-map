      "Extreme": "#991B1B"
    }},
    { "key": "fireFrequency", "label": "Fire Frequency", "type": "text" },
    { "key": "dominantVegetation", "label": "Dominant Vegetation", "type": "text" },
    { "key": "fireSeasonMonths", "label": "Fire Season", "type": "text" },
    { "key": "areaBurnedAnnual", "label": "Avg. Annual Area Burned (ha)", "type": "text" },
    { "key": "yearOfEvent", "label": "Year", "type": "text" },
    { "key": "areaBurned", "label": "Area Burned (ha)", "type": "formatted-number" },
    { "key": "cause", "label": "Primary Cause", "type": "text" },
    { "key": "seasonalPattern", "label": "Seasonal Pattern", "type": "markdown" },
    { "key": "historicalFires", "label": "Historical Fire Data", "type": "tags" },
    { "key": "description", "label": "Description", "type": "markdown" }
  ]
