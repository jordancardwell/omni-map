  "dataType": "regions",
  "dataSource": "static",
  "category": "Climate & Environment",
  "thumbnail": "#EF4444",
  "schema": "WildfireRiskMetadata",
  "sidebarConfig": {
    "idField": "code",
    "searchFields": ["code", "name", "region", "riskLevel", "dominantVegetation", "description"],
    "groupBy": "riskGroup",
    "titleField": "name",
    "subtitleField": "region",
    "badgeField": "riskLevel",
    "badgeFormat": "text"
  },
  "detailPanelConfig": {
    "titleField": "name",
    "subtitleField": "region"
  },
  "detailFields": [
    { "key": "riskLevel", "label": "Fire Risk Level", "type": "status-badge", "statusColors": {
      "Low": "#EAB308",
      "Moderate": "#F97316",
