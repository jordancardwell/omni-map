  "thumbnail": "#3B82F6",
  "schema": "WaterScarcityMetadata",
  "sidebarConfig": {
    "idField": "code",
    "searchFields": ["code", "name", "region", "waterStressLevel", "droughtRisk", "description"],
    "groupBy": "stressGroup",
    "titleField": "name",
    "subtitleField": "region",
    "badgeField": "affectedPopulation",
    "badgeFormat": "formatted-number"
  },
  "detailPanelConfig": {
    "titleField": "name",
    "subtitleField": "region"
  },
  "detailFields": [
