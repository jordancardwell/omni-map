      "Low": "#3B82F6",
      "Low-Medium": "#06B6D4",
      "Medium-High": "#EAB308",
      "High": "#F97316",
      "Extremely High": "#EF4444"
    }},
    { "key": "waterStressRatio", "label": "Water Stress Ratio", "type": "text" },
    { "key": "depletionRate", "label": "Depletion Rate", "type": "text" },
    { "key": "droughtRisk", "label": "Drought Risk", "type": "status-badge", "statusColors": {
      "Low": "#3B82F6",
      "Moderate": "#06B6D4",
      "High": "#EAB308",
      "Very High": "#F97316",
      "Extreme": "#EF4444"
    }},
    { "key": "seasonalVariability", "label": "Seasonal Variability", "type": "status-badge", "statusColors": {
      "Low": "#3B82F6",
      "Moderate": "#06B6D4",
      "High": "#EAB308",
      "Very High": "#F97316"
    }},
    { "key": "affectedPopulation", "label": "Affected Population", "type": "formatted-number" },
    { "key": "riskFactors", "label": "Risk Factors", "type": "tags" },
    { "key": "description", "label": "Description", "type": "markdown" }
